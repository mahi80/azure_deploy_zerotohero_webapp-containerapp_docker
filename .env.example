# ══════════════════════════════════════════════════════════════════
# .env.example  —  Copy to .env and fill in real values.
#
# NEVER commit .env to git.  .gitignore already excludes it.
# For production, inject these via:
#   - Azure App Service → Configuration → Application settings
#   - GitHub Actions → Repository Secrets
#   - Docker run -e KEY=VALUE or docker-compose environment: section
# ══════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────
APP_NAME="CC Underwriting API"
APP_VERSION="1.0.0"
DEBUG=false

# ── Security ─────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
#   OR:     openssl rand -hex 32
SECRET_KEY=replace-with-64-char-hex-string-generated-by-openssl
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ─────────────────────────────────────────────────────
POSTGRES_DB=cc_underwriting
POSTGRES_USER=ccapi
POSTGRES_PASSWORD=replace-with-strong-password-min-16-chars
DATABASE_URL=postgresql://ccapi:replace-with-strong-password@db:5432/cc_underwriting

# ── Admin seed user ───────────────────────────────────────────────
# Created automatically on first startup if no users exist
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@SecurePass123
ADMIN_EMAIL=admin@yourcompany.com

# ── Model ────────────────────────────────────────────────────────
MODEL_PATH=models/cc_model_v1.joblib

# ── Azure Container Registry (for CI/CD and production) ──────────
ACR_LOGIN_SERVER=yourregistry.azurecr.io
ACR_USERNAME=yourregistry
ACR_PASSWORD=replace-with-acr-admin-password
IMAGE_NAME=cc-underwriting-api
IMAGE_TAG=latest

# ── Azure deployment (used by GitHub Actions) ────────────────────
AZURE_WEBAPP_NAME=cc-underwriting-api
AZURE_RESOURCE_GROUP=rg-cc-underwriting
AZURE_SUBSCRIPTION_ID=your-subscription-uuid
